{
  "name": "mistake-note-app",
  "version": "0.1.0",
  "description": "跨端错题整理与智能学习助手",
  "productName": "MistakeNote",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "dev:electron": "quasar dev -m electron",
    "dev:capacitor": "quasar dev -m capacitor",
    "build": "quasar build",
    "build:electron": "quasar build -m electron",
    "build:capacitor": "quasar build -m capacitor",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "quasar prepare --silent"
  },
  "dependencies": {
    "@capacitor/camera": "^8.2.1",
    "@capacitor/filesystem": "^7.0.0",
    "@quasar/extras": "^2.0.0",
    "@supabase/supabase-js": "^2.110.2",
    "comlink": "^4.4.2",
    "echarts": "^5.6.0",
    "katex": "^0.17.0",
    "marked": "^18.0.6",
    "pinia": "^3.0.1",
    "quasar": "^2.21.1",
    "sql.js": "^1.11.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@quasar/app-vite": "^3.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.19.11",
    "autoprefixer": "^10.4.27",
    "typescript": "^6.0.0",
    "vue-tsc": "^3.3.3"
  },
  "keywords": [
    "quasar",
    "mistake-note",
    "electron",
    "capacitor",
    "learning"
  ],
  "engines": {
    "node": ">= 26 || ^24 || ^22.12"
  }
}
